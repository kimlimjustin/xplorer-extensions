{
  "name": "xplorer-sqlite-browser",
  "version": "1.0.0",
  "description": "Browse and query SQLite databases with table navigation, data grid, and custom SQL",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform",
    "dev": "touch .hotreload && esbuild src/index.tsx --bundle --outfile=dist/index.js --watch --format=iife --external:react --external:react-dom --external:@xplorer/extension-sdk --define:process.env.NODE_ENV=\\\"development\\\"; rm -f .hotreload"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "sqlite-browser",
    "name": "SQLite Browser",
    "displayName": "SQLite Browser",
    "description": "Browse and query SQLite databases. Open any .db, .sqlite, or .sqlite3 file to explore tables, view data with pagination, and run custom SELECT queries.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "editor",
    "icon": "database",
    "keywords": ["editor", "sqlite", "database", "sql", "browser", "query"],
    "permissions": ["file:read"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "editors": [
        {
          "id": "sqlite-browser",
          "extensions": ["db", "sqlite", "sqlite3"],
          "priority": 30
        }
      ]
    }
  }
}
