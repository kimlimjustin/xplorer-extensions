{
  "name": "xplorer-image-gallery",
  "version": "1.0.0",
  "description": "Enhanced image preview with zoom and navigation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.2.0",
    "@types/react": "^18.0.0"
  },
  "xplorer": {
    "id": "xplorer-image-gallery",
    "name": "Image Gallery",
    "displayName": "Image Gallery",
    "description": "Enhanced image preview with zoom controls, image dimensions display, and prev/next navigation between images in the same directory.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "preview",
    "icon": "image",
    "keywords": ["preview", "image", "gallery", "zoom", "photo", "viewer"],
    "permissions": ["file:read", "directory:list"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "commands": [
        { "command": "preview", "title": "Preview Image", "category": "Image Gallery" }
      ]
    }
  }
}
