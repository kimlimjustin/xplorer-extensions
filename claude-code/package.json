{
  "name": "xplorer-claude-code",
  "version": "1.0.0",
  "description": "Claude Code integration for Xplorer — run AI coding commands from the bottom panel",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform",
    "watch": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform --watch",
    "dev": "touch .hotreload && esbuild src/index.tsx --bundle --outfile=dist/index.js --watch --format=iife --external:react --external:react-dom --external:@xplorer/extension-sdk --define:process.env.NODE_ENV=\\\"development\\\"; rm -f .hotreload"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "claude-code",
    "name": "Claude Code",
    "displayName": "Claude Code",
    "description": "Run Claude Code AI commands directly from Xplorer. Ask Claude to edit files, explain code, fix bugs, and more — all from a bottom panel.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "tool",
    "icon": "bot",
    "keywords": ["claude", "ai", "code", "terminal", "assistant"],
    "permissions": ["file:read", "file:write", "ui:panels", "system:exec", "ai:chat", "ai:read"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "commands": [
        {
          "id": "claude-code.open",
          "title": "Open Claude Code",
          "shortcut": "ctrl+shift+c"
        }
      ]
    }
  }
}
