{
  "name": "xplorer-file-organizer",
  "version": "1.0.0",
  "description": "AI-powered file organization suggestions",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "file-organizer",
    "name": "File Organizer",
    "displayName": "File Organizer",
    "description": "AI-powered file organization suggestions",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "panel",
    "icon": "folder",
    "permissions": ["file:read", "file:write", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
