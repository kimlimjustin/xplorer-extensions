{
  "name": "xplorer-markdown-preview",
  "version": "1.0.0",
  "description": "Preview Markdown files with formatted rendering",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "xplorer-markdown-preview",
    "name": "Markdown Preview",
    "displayName": "Markdown Preview",
    "description": "Preview Markdown files with formatted headings, code blocks, links, lists, and more. Renders .md files in the preview panel.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "preview",
    "icon": "file-text",
    "keywords": ["preview", "markdown", "md", "documentation", "rendering"],
    "permissions": ["file:read"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "commands": [
        { "command": "preview", "title": "Preview Markdown", "category": "Markdown" }
      ]
    }
  }
}
