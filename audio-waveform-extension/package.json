{
  "name": "audio-waveform-extension",
  "version": "1.0.0",
  "description": "Audio player with waveform visualization",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.2.0",
    "@types/react": "^18.0.0"
  },
  "xplorer": {
    "id": "audio-waveform",
    "name": "Audio Waveform",
    "displayName": "Audio Waveform",
    "description": "Audio player with waveform visualization for MP3, WAV, OGG, FLAC, AAC, M4A, and WMA files.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "preview",
    "icon": "music",
    "keywords": ["preview", "audio", "waveform", "music", "player", "sound"],
    "permissions": ["file:read"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "commands": [
        { "command": "preview", "title": "Preview Audio", "category": "Audio Waveform" }
      ]
    }
  }
}
