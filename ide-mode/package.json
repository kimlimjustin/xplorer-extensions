{
  "name": "xplorer-ide-mode",
  "version": "1.0.0",
  "description": "IDE mode with project sidebar, project detection, and file tree for Xplorer",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform",
    "dev": "touch .hotreload && esbuild src/index.tsx --bundle --outfile=dist/index.js --watch --format=iife --external:react --external:react-dom --external:@xplorer/extension-sdk --define:process.env.NODE_ENV=\\\"development\\\"; rm -f .hotreload"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "ide-mode",
    "name": "IDE Mode",
    "displayName": "IDE Mode",
    "description": "IDE mode with project sidebar, file tree, and project detection. Depends on Code Editor extension.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "panel",
    "icon": "layout",
    "keywords": ["ide", "project", "sidebar", "file-tree"],
    "dependencies": ["code-editor"],
    "permissions": ["file:read", "directory:list", "ui:panels"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "panels": [
        {
          "id": "ide-mode",
          "title": "Workspace",
          "location": "right",
          "icon": "folder-tree"
        }
      ]
    }
  }
}
