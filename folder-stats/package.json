{
  "name": "xplorer-folder-stats",
  "version": "1.0.0",
  "description": "Show file statistics and distribution for the current directory",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.2.0",
    "@types/react": "^18.0.0"
  },
  "xplorer": {
    "id": "xplorer-folder-stats",
    "name": "Folder Statistics",
    "displayName": "Folder Statistics",
    "description": "Displays file type distribution, size breakdown, and top largest files for the current directory in a sidebar panel.",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "panel",
    "icon": "bar-chart-3",
    "keywords": ["panel", "statistics", "analytics", "folder", "files", "distribution"],
    "permissions": ["file:read", "directory:list", "ui:panels"],
    "activationEvents": ["onStartup"],
    "contributes": {
      "panels": [
        { "id": "xplorer-folder-stats", "title": "Folder Stats", "location": "right", "icon": "bar-chart-3" }
      ]
    }
  }
}
