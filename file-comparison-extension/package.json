{
  "name": "xplorer-file-comparison",
  "version": "1.0.0",
  "description": "Compare two files side by side with diff highlighting",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "file-comparison",
    "name": "File Comparison",
    "displayName": "File Comparison",
    "description": "Compare two files side by side with diff highlighting",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "tool",
    "icon": "code",
    "permissions": ["file:read", "ui:panels"],
    "activationEvents": ["onCommand:file-comparison.compare"]
  }
}
