{
  "name": "xplorer-bulk-rename",
  "version": "1.0.0",
  "description": "Bulk rename files using regex patterns with live preview",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "bulk-rename-dialog",
    "name": "Bulk Rename",
    "displayName": "Bulk Rename",
    "description": "Bulk rename files using regex patterns with live preview",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "tool",
    "icon": "file-text",
    "permissions": ["file:read", "file:write", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
