{
  "name": "xplorer-open-with",
  "version": "1.0.0",
  "description": "Open files with different applications",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "open-with-dialog",
    "name": "Open With",
    "displayName": "Open With",
    "description": "Open files with different applications",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "tool",
    "icon": "layout",
    "permissions": ["file:read", "file:execute", "file:write", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
