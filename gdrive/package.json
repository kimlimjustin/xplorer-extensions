{
  "name": "xplorer-gdrive",
  "version": "1.0.0",
  "description": "Google Drive integration for Xplorer",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform",
    "dev": "touch .hotreload && esbuild src/index.tsx --bundle --outfile=dist/index.js --watch --format=iife --external:react --external:react-dom --external:@xplorer/extension-sdk --define:process.env.NODE_ENV=\\\"development\\\"; rm -f .hotreload"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "gdrive",
    "name": "Google Drive",
    "displayName": "Google Drive",
    "description": "Browse and manage Google Drive files directly from Xplorer",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "tab",
    "icon": "cloud",
    "permissions": ["gdrive:access", "file:read", "file:write", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
