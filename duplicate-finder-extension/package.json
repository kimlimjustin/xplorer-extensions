{
  "name": "xplorer-duplicate-finder",
  "version": "1.0.0",
  "description": "Find and manage duplicate files",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "duplicate-finder",
    "name": "Duplicate Finder",
    "displayName": "Duplicate Finder",
    "description": "Find and manage duplicate files in your directories",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "panel",
    "icon": "search",
    "permissions": ["file:read", "search:duplicates", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
