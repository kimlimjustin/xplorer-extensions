{
  "name": "xplorer-recommendations",
  "version": "1.0.0",
  "description": "Find similar files and get file recommendations",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform",
    "watch": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform --watch"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "recommendations",
    "name": "Recommendations",
    "displayName": "Similar & Recommendations",
    "description": "Find similar files and get file recommendations",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "panel",
    "icon": "target",
    "permissions": ["file:read", "search:read", "search:duplicates", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
