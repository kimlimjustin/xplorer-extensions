{
  "name": "@xplorer/git-extension",
  "version": "1.0.0",
  "description": "Git commit graph, file history, blame, and branch management",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/index.js --external:react --external:react-dom --external:@xplorer/extension-sdk --target=es2020 --jsx=transform"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.0"
  },
  "xplorer": {
    "id": "git",
    "name": "Git Integration",
    "displayName": "Git Integration",
    "description": "Git commit graph, file history, blame, and branch management",
    "version": "1.0.0",
    "author": "Xplorer Team",
    "category": "bottom-tab",
    "icon": "git-branch",
    "permissions": ["git:read", "git:write", "ui:panels"],
    "activationEvents": ["onStartup"]
  }
}
